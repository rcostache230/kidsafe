---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang?: "en" | "ro";
  canonical?: string;
  image?: string;
}

const { title, description, lang = "ro", canonical, image } = Astro.props;
const siteName = "Digital Parents";
const imageUrl = image
  ? new URL(image, "https://digitalparents.xyz").toString()
  : undefined;
const homeHref = lang === "ro" ? "/" : "/en";
const blogHref = lang === "ro" ? "/blog" : "/blog/en";
const switchLangHref = lang === "ro" ? "/blog/en" : "/blog";
const switchLangLabel = lang === "ro" ? "EN" : "RO";
const navGuides = lang === "ro" ? "Ghiduri" : "Guides";
const navArticles = lang === "ro" ? "Articole" : "Articles";
const navAbout = lang === "ro" ? "Despre" : "About";
const footerCopy =
  lang === "ro"
    ? "© 2026 Digital Parents. Proiect independent realizat de Razvan Costache."
    : "© 2026 Digital Parents. Independent project by Razvan Costache.";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {canonical ? <link rel="canonical" href={canonical} /> : null}
    <title>{title} — {siteName}</title>
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    {imageUrl ? <meta property="og:image" content={imageUrl} /> : null}
    <meta name="twitter:card" content="summary_large_image" />
    {imageUrl ? <meta name="twitter:image" content={imageUrl} /> : null}
  </head>
  <body>
    <header class="site-header">
      <div class="shell row">
        <a class="brand" href={homeHref} aria-label="digitalparents.xyz">
          <span class="brand-mark" aria-hidden="true">
            <img src="/brand/digitalparents-logo-mark.png" alt="" width="40" height="40" draggable="false" />
          </span>
          <span>digitalparents<span class="brand-dot">.xyz</span></span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a href={`${homeHref}#apps`}>{navGuides}</a>
          <a href={blogHref} aria-current={Astro.url.pathname === blogHref ? "page" : undefined}>{navArticles}</a>
          <a href={`${homeHref}#about`}>{navAbout}</a>
        </nav>
        <a class="lang-switch" href={switchLangHref} style="text-decoration:none; border:1px solid var(--paper-line); border-radius:999px; padding:0.4rem 0.75rem; font-size:14px; font-weight:600; color:var(--brand-700); background:#fff;" aria-label={switchLangLabel === "RO" ? "Switch to Romanian" : "Switch to English"}>
          {switchLangLabel}
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="shell">
        <p>{footerCopy}</p>
        <p style="margin-top:0.5rem;">
          <a href={homeHref}>{lang === "ro" ? "Înapoi la ghiduri" : "Back to guides"}</a>
          ·
          <a href="https://www.linkedin.com/in/rcostache/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </p>
      </div>
    </footer>
  </body>
</html>
