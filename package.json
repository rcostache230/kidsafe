{
  "name": "digital-parents",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/blog"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:blog": "npm --prefix apps/blog run dev",
    "build:blog": "npm --prefix apps/blog run build",
    "build:next": "next build --webpack",
    "build": "npm run build:blog && npm run build:next",
    "start": "next start",
    "lint": "next lint",
    "install:all": "npm install && npm --prefix apps/blog install"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "next": "^16.1.7",
    "react": "^19.1.4",
    "react-dom": "^19.1.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
